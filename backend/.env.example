NODE_ENV=development
PORT=5001
APP_URL=http://localhost:5001
FRONTEND_URL=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/ai-marketing-studio
REDIS_URL=redis://127.0.0.1:6379
QUEUE_MODE=bullmq

OPENAI_API_KEY=your_openai_or_openrouter_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SITE_URL=http://localhost:5173
OPENAI_APP_NAME=AI Marketing Studio
OPENAI_MODEL=gpt-4o-mini

DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

PEXELS_API_KEY=your_pexels_api_key
FAL_KEY=your_fal_api_key

INITIAL_USER_CREDITS=5
LOW_CREDIT_THRESHOLD=2

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_PREMIUM_PRICE_ID=price_premium_monthly
STRIPE_CREDIT_PACK_10_PRICE_ID=price_credits_10
STRIPE_CREDIT_PACK_50_PRICE_ID=price_credits_50
STRIPE_CREDIT_PACK_100_PRICE_ID=price_credits_100

# Optional experimental image fallback providers
REPLICATE_API_TOKEN=your_replicate_token
REPLICATE_MODEL=black-forest-labs/flux-kontext-max
REPLICATE_POLL_INTERVAL_MS=1500

STABILITY_API_KEY=your_stability_api_key
STABILITY_ENGINE_ID=stable-diffusion-xl-1024-v1-0

PIXABAY_API_KEY=your_pixabay_api_key
LOCAL_MUSIC_PATH=./assets/music/default-bed.mp3

STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

CACHE_TTL_HOURS=24
JOB_CONCURRENCY=2
